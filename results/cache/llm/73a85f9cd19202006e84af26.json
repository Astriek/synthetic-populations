  "prompt": "\u092e\u0947\u0930\u093e \u0928\u093e\u092e \u0930\u092e\u0947\u0936 \u0939\u0948\u0964 \u092e\u0948\u0902 Jammu & Kashmir \u092e\u0947\u0902 naukri-peshaa mazdoor \u0939\u0942\u0901\u0964 \u092e\u0948\u0902 \u092e\u0939\u0940\u0928\u0947 \u092e\u0947\u0902 \u0932\u0917\u092d\u0917 6185 \u0930\u0941\u092a\u092f\u0947 \u0915\u092e\u093e\u0924\u093e \u0939\u0942\u0901\u0964 \u092e\u0947\u0930\u0947 \u092a\u093e\u0938 \u0915\u094b\u0908 \u0932\u093f\u0916\u093f\u0924 \u0905\u0928\u0941\u092c\u0902\u0927 \u0928\u0939\u0940\u0902 \u0939\u0948\u0964 \u092e\u0941\u091d\u0947 \u0915\u094c\u0928-\u0915\u094c\u0928 \u0938\u0940 \u0938\u0930\u0915\u093e\u0930\u0940 \u0915\u0932\u094d\u092f\u093e\u0923 \u092f\u094b\u091c\u0928\u093e\u0913\u0902 \u0915\u093e \u0932\u093e\u092d \u092e\u093f\u0932 \u0938\u0915\u0924\u093e \u0939\u0948? \u092f\u094b\u091c\u0928\u093e\u0913\u0902 \u0915\u0947 \u0928\u093e\u092e \u092c\u0924\u093e\u0907\u090f\u0964",
